# ============================================================
# .env.example — Copy to .env and fill in your values
# cp .env.example .env
# ============================================================
# NEVER commit the real .env file — it's in .gitignore

# --- DuckDNS ---
DUCKDNS_DOMAIN=your-domain          # e.g. my-server
DUCKDNS_TOKEN=your-token-here       # from duckdns.org/domains

# --- Server Network ---
SERVER_LAN_IP=192.168.1.XXX         # your server's local static IP
GATEWAY_IP=192.168.1.1              # your router IP

# --- Immich ---
# These go into docker-compose.yml for Immich
DB_PASSWORD=change-me-strong-password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# --- Domain ---
DOMAIN=your-domain.duckdns.org      # full domain for Nginx SSL config

# --- Tailscale ---
# Tailscale IP is auto-assigned, no secret needed here
# Just run: sudo tailscale up

# --- Let's Encrypt ---
CERTBOT_EMAIL=your@email.com        # used during certbot setup
